#!/bin/sh

MSG_FILE="$1"
SOURCE="$2"

if [ -n "$SOURCE" ]; then
  exit 0
fi

if git diff --cached --quiet; then
  exit 0
fi


prompt="
Generate a git commit message strictly from the staged diff.

=== FORMAT (Conventional Commits) ===
<type>(<scope>): <subject>

[optional body]

[optional footer]

=== HARD CONSTRAINTS ===
- Output ONLY the commit message. No explanations, no quotes, no markdown.
- Header MUST be ≤ 72 characters.
- Use imperative mood (e.g., 'add', 'fix', not 'added', 'fixes').
- Use present tense.
- Scope:
  - Use the smallest precise scope derived from file paths or module names.
  - Omit scope if unclear.
- Type MUST be one of:
  feat, fix, docs, style, refactor, perf, test, build, ci, chore

=== SEMANTIC RULES ===
- Prioritize WHAT and WHY over HOW.
- If multiple changes exist:
  - Select the dominant logical change.
  - Ignore minor or incidental edits.
- If change is unclear:
  - Choose the safest, most descriptive interpretation.
- If no meaningful change:
  - Output exactly: chore: no-op

=== BODY RULES (optional) ===
- Include ONLY if necessary for clarity.
- Wrap at ≤ 72 characters per line.
- Explain intent, rationale, or impact (NOT implementation details).

=== FOOTER RULES (optional) ===
- Use ONLY for:
  - BREAKING CHANGE:
  - Refs: #<issue>
- Follow Conventional Commits footer syntax strictly.

=== CONTEXT ===
Recent commits (for style consistency only; do NOT copy wording):
$(git --no-pager log -10 --oneline)

=== INPUT ===
Staged diff:
$(git diff --cached)

=== OUTPUT ===
- Single commit message.
- Optional alternatives MAY be included ONLY as commented lines starting with '#'.
"

if command -v gemini >/dev/null 2>&1; then
  COMMIT_MSG="$(gemini "${prompt}")"

  if [ -n "$COMMIT_MSG" ]; then
    echo "$COMMIT_MSG" > "$MSG_FILE"
  fi
fi

exit 0
